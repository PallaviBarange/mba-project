<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>User Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

  <style>
    body {
      min-height: 100vh;
      background: url("/images/background.jpg") no-repeat center center / cover;
      font-family: Arial, sans-serif;
    }

    .glass-card {
      background-color: rgba(255, 255, 255, 0.12); 
      backdrop-filter: blur(10px); 
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.2);
    }

    .glass-header {
      background-color: rgba(13, 110, 253, 0.9);
    }

    .glass-card input,
    .glass-card select {
      background-color: rgba(255,255,255,0.2);
      color: white;
      border: 1px solid rgba(255,255,255,0.3);
      border-radius: 6px;
    }

    .glass-card input::placeholder,
    .glass-card select::placeholder {
      color: rgba(255,255,255,0.7);
    }

    .filter-form .form-select {
      background-color: rgba(255,255,255,0.2);
      color: white;
      border: 1px solid rgba(255,255,255,0.3);
    }

    .filter-form .form-select option {
      color: black;
    }

    .btn-primary {
      background-color: #0d6efd;
      border: none;
    }

    .btn-primary:hover {
      background-color: #084298;
    }

    .card-title, .card-text {
      color: white;
    }

    .navbar-text {
      color: white;
    }

  </style>
</head>

<body>

  <nav class="navbar navbar-expand-lg navbar-dark glass-header shadow">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/user/dashboard">
        <i class="bi bi-film"></i> Movie Booking
      </a>

      <div class="navbar-nav ms-auto align-items-center">
        <span class="navbar-text me-3">
          Welcome, <strong><%= username %></strong>
        </span>
        <a href="/user/my-bookings" class="btn btn-outline-light me-2">
          My Bookings
        </a>
        <a href="/user/logout" class="btn btn-light">
          Logout
        </a>
      </div>
    </div>
  </nav>

  <div class="container mt-4">

    <% if (successMsg && successMsg.length > 0) { %>
      <div class="alert alert-success alert-dismissible fade show glass-card">
        <%= successMsg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <form method="GET" action="/user/dashboard" class="mb-4 filter-form d-flex gap-2">
      <select name="movie" class="form-select glass-card">
        <option value="">-- Select Movie --</option>
        <% movieNames.forEach(name => { %>
          <option value="<%= name %>" <%= selectedMovie === name ? "selected" : "" %>>
            <%= name %>
          </option>
        <% }) %>
      </select>
      <button type="submit" class="btn btn-primary">
        <i class="bi bi-funnel"></i> Filter
      </button>
    </form>

    <div class="row">
      <% if (movies && movies.length > 0) { %>
        <% movies.forEach(movie => { %>

          <div class="col-md-4 mb-4">
            <div class="card h-100 glass-card text-white shadow-lg border-0">

              <% if (movie.image) { %>
                <img src="/uploads/<%= movie.image %>" class="card-img-top" alt="<%= movie.name %>">
              <% } %>

              <div class="card-body d-flex flex-column">

                <h5 class="card-title fw-bold">
                  <%= movie.name %>
                </h5>

                <p class="card-text small">
                  <strong>Theatre:</strong> <%= movie.theatreName %> <br>
                  <strong>Hero:</strong> <%= movie.hero %><br>
                  <strong>Heroine:</strong> <%= movie.heroine %><br>
                  <strong>Director:</strong> <%= movie.director %><br>
                  <strong>Duration:</strong> <%= movie.duration %><br>
                  <strong>Start Time:</strong> <%= movie.time %><br>
                  <strong>Booked Seats:</strong> <%= movie.bookedSeatsCount || 0 %>
                </p>

                <div class="mt-auto d-grid">
                  <a href="/user/booking/<%= movie._id %>" class="btn btn-success">
                    <i class="bi bi-ticket-perforated"></i> Book Now
                  </a>
                </div>

              </div>

            </div>
          </div>

        <% }) %>
      <% } else { %>
        <p class="text-center text-white">No movies available.</p>
      <% } %>

    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
