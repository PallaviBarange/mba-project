<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Seats - <%= movie.name %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

  <style>
    body {
      min-height: 100vh;
      background: url("/images/background.jpg") no-repeat center center / cover;
    }

    .glass-card {
      background-color: rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(10px);
    }

    .seat-container {
      display: grid;
      grid-template-columns: repeat(10, 45px);
      gap: 8px;
      justify-content: center;
    }

    .seat {
      width: 45px;
      height: 45px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 12px;
      font-weight: bold;
      background-color: #e9ecef;
      color: #000;
      user-select: none;
    }

    .seat.available:hover {
      background-color: #0d6efd;
      color: #fff;
    }

    .seat.selected {
      background-color: #198754;
      color: #fff;
    }

    .seat.booked {
      background-color: #dc3545;
      color: #fff;
      cursor: not-allowed;
    }

    .screen {
      background-color: #adb5bd;
      height: 35px;
      border-radius: 5px;
      text-align: center;
      line-height: 35px;
      font-weight: bold;
      margin-bottom: 25px;
    }
  </style>
</head>

<body>

  <div class="container py-4">

    <div class="card glass-card text-white shadow-lg border-0">

      <div class="card-header bg-primary text-center fw-bold fs-4">
        <i class="bi bi-chair"></i> Select Seats
      </div>

      <div class="card-body">

        <h5 class="text-center mb-2">
          Movie: <strong><%= movie.name %></strong>
        </h5>

        <p class="text-center mb-4">
          Showtime: <%= movie.time %>
        </p>

        <div class="screen text-dark mb-4">
          SCREEN THIS WAY
        </div>

        <div class="seat-container mb-4">
          <% allSeats.forEach(seatId => { 
               const isBooked = bookedSeats.includes(seatId);
          %>
            <div 
              class="seat <%= isBooked ? 'booked' : 'available' %>" 
              data-seat="<%= seatId %>">
              <%= seatId %>
            </div>
          <% }) %>
        </div>

        <div class="d-flex justify-content-center gap-4 mb-4">
          <span><span class="seat available"></span> Available</span>
          <span><span class="seat selected"></span> Selected</span>
          <span><span class="seat booked"></span> Booked</span>
        </div>

        <form action="/user/confirm-booking/<%= movie._id %>" method="POST">
          <input type="hidden" name="seats" id="selectedSeats">

          <div class="d-grid">
            <button type="submit" class="btn btn-success btn-lg">
              <i class="bi bi-ticket-perforated"></i> Confirm Booking
            </button>
          </div>
        </form>

      </div>
    </div>

  </div>

  <script>
    const seats = document.querySelectorAll(".seat.available");
    const selectedSeatsInput = document.getElementById("selectedSeats");

    let selected = [];

    seats.forEach(seat => {
      seat.addEventListener("click", () => {
        const seatId = seat.dataset.seat;

        if (seat.classList.contains("selected")) {
          seat.classList.remove("selected");
          selected = selected.filter(s => s !== seatId);
        } else {
          seat.classList.add("selected");
          selected.push(seatId);
        }

        selectedSeatsInput.value = selected.join(",");
      });
    });
  </script>

</body>
</html>