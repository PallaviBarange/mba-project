<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Bookings</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

  <style>
    body {
      min-height: 100vh;
      background: url("/images/background.jpg") no-repeat center center / cover;
    }

    .glass-card {
      background-color: rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(10px);
    }

    .glass-header {
      background-color: rgba(13, 110, 253, 0.85);
    }

    .text-light-muted {
      color: #e6e6e6;
    }
  </style>
</head>

<body>

  <nav class="navbar navbar-expand-lg navbar-dark glass-header shadow">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/user/dashboard">
        <i class="bi bi-film"></i> Movie Booking
      </a>

      <div class="navbar-nav ms-auto align-items-center">
        <span class="navbar-text me-3 text-white">
          Welcome, <strong><%= userName %></strong>
        </span>
        <a href="/user/dashboard" class="btn btn-outline-light me-2">
          Dashboard
        </a>
        <a href="/user/logout" class="btn btn-light">
          Logout
        </a>
      </div>
    </div>
  </nav>

  <div class="container mt-4">

    <h2 class="mb-4 text-white">
      <i class="bi bi-ticket-perforated"></i> My Bookings
    </h2>

    <% if (bookings.length === 0) { %>
      <div class="alert alert-info">
        You haven't made any bookings yet.
      </div>
    <% } else { %>

      <div class="row">
        <% bookings.forEach(booking => { %>

          <div class="col-md-6 mb-4">
            <div class="card glass-card text-white shadow-lg border-0">

              <div class="card-body">
                <div class="row g-3 align-items-center">

                  <div class="col-4">
                    <img
                      src="/uploads/<%= booking.movieId.poster %>"
                      class="img-fluid rounded shadow"
                      alt="<%= booking.movieId.name %>">
                  </div>

                  <div class="col-8">
                    <h5 class="fw-bold mb-2"><%= booking.movieId.name %></h5>

                    <p class="mb-1 text-light-muted">
                      <i class="bi bi-building"></i>
                      <strong><%= booking.movieId.theatreId.name %></strong>
                    </p>

                    <p class="mb-1 text-light-muted">
                      <i class="bi bi-clock"></i>
                       <%= booking.movieId.startTime %>
                    </p>

                    <p class="mb-1 text-light-muted">
                      <i class="bi bi-calendar"></i>
                      <%= new Date(booking.bookingDate).toLocaleDateString() %>
                    </p>

                    <p class="mb-1 text-light-muted">
                      <i class="bi bi-ticket"></i>
                      <strong>Seats:</strong>
                      <%= booking.seats.join(', ') %>
                    </p>

                    <p class="mb-0">
                      <strong>Total Seats:</strong>
                      <%= booking.totalSeats %>
                    </p>
                  </div>

                </div>
              </div>

            </div>
          </div>

        <% }) %>
      </div>

    <% } %>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
