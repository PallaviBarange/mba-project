<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Theatre Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            min-height: 100vh;
            background: url("/images/background.jpg") no-repeat center center / cover;
        }
        .card-body {
            background-color: rgba(255, 255, 255, 0.12);
            backdrop-filter: blur(8px);
        }
        .card-title {
            font-weight: bold;
        }
        ::placeholder {
            color: #f1f1f1;
        }
    </style>
</head>
<body class="d-flex flex-column align-items-center py-5">

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
            <h2 class="text-white">Welcome, <%= theatreName %></h2>
            <a href="/theatre/logout" class="btn btn-danger">Logout</a>
        </div>

        <a href="/theatre/add-movie" class="btn btn-primary mb-4">Add New Movie</a>

        <h4 class="text-white mb-3">My Movies</h4>
        <div class="row">
            <% if (movies.length === 0) { %>
                <div class="col-12 text-white">No movies added yet.</div>
            <% } %>

            <% movies.forEach(movie => { %>
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm rounded">
                        <% if (movie.image) { %>
                            <img src="/uploads/<%= movie.image %>" class="card-img-top" alt="<%= movie.name %>">
                        <% } else { %>
                            <img src="/images/default-poster.jpg" class="card-img-top" alt="No Image">
                        <% } %>
                        <div class="card-body">
                            <h5 class="card-title text-white"><%= movie.name %></h5>
                            <p class="card-text text-white">
                                <strong>Theatre:</strong> <%= movie.theatreName %> <br>
                                <strong>Description:</strong> <%= movie.description %> <br>
                                <strong>Hero:</strong> <%= movie.hero %> <br>
                                <strong>Heroine:</strong> <%= movie.heroine %> <br>
                                <strong>Director:</strong> <%= movie.director %> <br>
                                <strong>Duration:</strong> <%= movie.duration %> <br>
                                <strong>Start Time:</strong> <%= movie.time %>
                            </p>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

</body>
</html>
