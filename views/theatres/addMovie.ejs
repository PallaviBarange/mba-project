<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add Movie</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      min-height: 100vh;
      background: url("/images/background.jpg") no-repeat center center / cover;
      font-family: Arial, sans-serif;
    }

    .glass-card {
      background-color: rgba(255, 255, 255, 0.15); 
      backdrop-filter: blur(10px); 
      -webkit-backdrop-filter: blur(10px);
      border-radius: 12px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
      padding: 20px;
      color: #fff;
    }
    ::placeholder {
      color: #f1f1f1;
      opacity: 1;
    }

    .form-control, .form-select, textarea {
      background-color: rgba(255, 255, 255, 0.1);
      border: none;
      color: #fff;
      border-radius: 6px;
    }

    .form-control:focus, .form-select:focus, textarea:focus {
      background-color: rgba(255, 255, 255, 0.2);
      color: #fff;
      box-shadow: none;
    }

    .card h5, .card p {
      color: #fff !important;
    }

    .btn-primary {
      background-color: #0d6efd;
      border: none;
    }

    .btn-primary:hover {
      background-color: #084298;
    }

    .movie-card {
      background-color: rgba(0, 0, 0, 0.25);
      backdrop-filter: blur(5px);
      border-radius: 10px;
    }

    img.card-img-top {
      border-top-left-radius: 10px;
      border-top-right-radius: 10px;
    }

    .theatre-name {
      font-weight: bold;
      margin-bottom: 5px;
      color: #ffd700; /* golden color for theatre name */
    }

  </style>
</head>
<body class="d-flex flex-column align-items-center justify-content-start py-4">

  <div class="container">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3 class="text-white">Welcome, <%= theatreName %></h3>
      <div>
        <a href="/theatre/dashboard" class="btn btn-secondary">Dashboard</a>
        <a href="/theatre/logout" class="btn btn-danger ms-2">Logout</a>
      </div>
    </div>

    <% if (message) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <div class="glass-card mb-4">
      <h5 class="mb-3">Add New Movie</h5>
      <form action="/theatre/add-movie" method="POST" enctype="multipart/form-data">
        <input type="file" name="image" class="form-control mb-2" required>
        <input type="text" name="name" class="form-control mb-2" placeholder="Movie Name" required>
        <textarea name="description" class="form-control mb-2" placeholder="Description" rows="2" required></textarea>
        <input type="text" name="hero" class="form-control mb-2" placeholder="Hero" required>
        <input type="text" name="heroine" class="form-control mb-2" placeholder="Heroine" required>
        <input type="text" name="director" class="form-control mb-2" placeholder="Director" required>
        <input type="text" name="duration" class="form-control mb-2" placeholder="Duration" required>
        <input type="text" name="time" class="form-control mb-2" placeholder="Start Time" required>
        <button type="submit" class="btn btn-primary w-100">Add Movie</button>
      </form>
    </div>

    <div class="row">
      <% if (movies && movies.length > 0) { %>
        <% movies.forEach(movie => { %>
          <div class="col-md-4 mb-3">
            <div class="movie-card card h-100 text-white">
              <% if (movie.image) { %>
                <img src="/uploads/<%= movie.image %>" class="card-img-top mb-2" alt="Poster">
              <% } %>
              <div class="card-body">
                <div class="theatre-name"><%= movie.theatreName %></div>
                <h5 class="card-title"><%= movie.name %></h5>
                <p class="card-text"><strong>Description:</strong> <%= movie.description %></p>
                <p class="card-text"><strong>Hero:</strong> <%= movie.hero %></p>
                <p class="card-text"><strong>Heroine:</strong> <%= movie.heroine %></p>
                <p class="card-text"><strong>Director:</strong> <%= movie.director %></p>
                <p class="card-text"><strong>Duration:</strong> <%= movie.duration %></p>
                <p class="card-text"><strong>Time:</strong> <%= movie.time %></p>
                <a href="/theatre/edit-movie/<%= movie._id %>" class="btn btn-warning btn-sm">Edit</a>
                <a href="/theatre/delete-movie/<%= movie._id %>" class="btn btn-danger btn-sm">Delete</a>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-center text-white">No movies added yet.</p>
      <% } %>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>