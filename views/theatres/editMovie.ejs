<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Movie - <%= movie.name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  
  <style>
    body {
      min-height: 100vh;
      background: url("/images/background.jpg") no-repeat center center / cover;
    }

    .glass-card {
      background-color: rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(10px);
    }

    ::placeholder {
      color: #f1f1f1;
    }
  </style>
</head>
<body class="d-flex align-items-center justify-content-center">

  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">

        <div class="card shadow-lg border-0 glass-card text-white">

          <div class="card-header bg-primary text-center fw-bold fs-4">
            Edit Movie - <%= movie.name %>
          </div>

          <div class="card-body p-4">

            <form action="/theatre/edit-movie/<%= movie._id %>" method="POST" enctype="multipart/form-data">
              <input type="hidden" name="movieId" value="<%= movie._id %>">

              <div class="mb-3">
                <label class="form-label">Poster</label>
                <input type="file" name="image" class="form-control bg-transparent text-white border-light">
                <input type="hidden" name="oldImage" value="<%= movie.image %>">
              </div>

              <div class="mb-3">
                <label class="form-label">Name</label>
                <input type="text" name="name" value="<%= movie.name %>" class="form-control bg-transparent text-white border-light">
              </div>

              <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control bg-transparent text-white border-light"><%= movie.description %></textarea>
              </div>

              <div class="mb-3">
                <label class="form-label">Hero</label>
                <input type="text" name="hero" value="<%= movie.hero %>" class="form-control bg-transparent text-white border-light">
              </div>

              <div class="mb-3">
                <label class="form-label">Heroine</label>
                <input type="text" name="heroine" value="<%= movie.heroine %>" class="form-control bg-transparent text-white border-light">
              </div>

              <div class="mb-3">
                <label class="form-label">Director</label>
                <input type="text" name="director" value="<%= movie.director %>" class="form-control bg-transparent text-white border-light">
              </div>

              <div class="mb-3">
                <label class="form-label">Duration</label>
                <input type="text" name="duration" value="<%= movie.duration %>" class="form-control bg-transparent text-white border-light">
              </div>

              <div class="mb-4">
                <label class="form-label">Start Time</label>
                <input type="text" name="time" value="<%= movie.time %>" class="form-control bg-transparent text-white border-light">
              </div>

              <div class="d-grid mb-2">
                <button type="submit" class="btn btn-primary btn-lg">Update Movie</button>
              </div>

              <div class="d-grid">
                <a href="/theatre/dashboard" class="btn btn-secondary btn-lg">Cancel</a>
              </div>

            </form>

          </div>

        </div>

      </div>
    </div>
  </div>

</body>
</html>
